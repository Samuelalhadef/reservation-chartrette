# =========================================================
#  Variables d'environnement — Réservation Chartrettes
#  À renseigner dans Portainer (onglet "Environment variables"
#  de la stack), PAS dans un fichier commité.
# =========================================================

# --- Stack "reservation-chartrettes" ---

# Port exposé sur l'hôte TrueNAS (le conteneur écoute toujours sur 3000 en interne)
APP_PORT=8080

# Chemin sur le TrueNAS du dataset contenant la base SQLite
DB_HOST_PATH=/mnt/tank/reservation-chartrettes/db

# Base SQLite locale (mode fichier libSQL).
# Par défaut : file:/data/app.db (chemin INTERNE au conteneur).
# Pour repointer vers Turso distant, mets une URL libsql://...
TURSO_DATABASE_URL=file:/data/app.db
# TURSO_AUTH_TOKEN= (uniquement si TURSO_DATABASE_URL pointe sur Turso distant)

# --- NextAuth ---
# URL publique EXACTE par laquelle on accède à l'app (= ce que tape l'utilisateur).
NEXTAUTH_URL=https://chartrettes-reservation.mousequetaire.com
# Générer avec : openssl rand -base64 32
NEXTAUTH_SECRET=changez_moi_avec_une_longue_chaine_aleatoire

# --- Google OAuth (laisser vide si non utilisé) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- E-mail (NodeMailer, optionnel) ---
EMAIL_SERVER_HOST=smtp.gmail.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=votre_adresse@gmail.com
EMAIL_SERVER_PASSWORD=mot_de_passe_application
EMAIL_FROM=noreply@chartrettes-reservation.mousequetaire.com


# =========================================================
#  Stack "cloudflared-reservation" (tunnel public)
# =========================================================

# Token du tunnel Cloudflare (créé via Zero Trust → Networks → Tunnels)
TUNNEL_TOKEN=eyJhIjoi...colle_ton_token_ici...
