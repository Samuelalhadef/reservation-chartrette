# =========================================================
#  Variables d'environnement — Réservation Chartrettes
#  À renseigner dans Portainer (onglet "Environment variables"
#  de la stack), PAS dans un fichier commité.
# =========================================================

# Port exposé sur l'hôte TrueNAS (le conteneur écoute toujours sur 3000)
APP_PORT=3000

# --- Base de données Turso (libSQL) ---
TURSO_DATABASE_URL=libsql://votre-base.turso.io
TURSO_AUTH_TOKEN=votre_token_turso

# --- NextAuth ---
# URL publique EXACTE par laquelle on accède à l'app (reverse proxy inclus).
# Ex: https://reservation.mondomaine.fr  ou  http://IP_TRUENAS:3000
NEXTAUTH_URL=https://reservation.mondomaine.fr
# Générer avec: openssl rand -base64 32
NEXTAUTH_SECRET=changez_moi_avec_une_longue_chaine_aleatoire

# --- Google OAuth (laisser vide si non utilisé) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- E-mail (NodeMailer) ---
EMAIL_SERVER_HOST=smtp.gmail.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=votre_adresse@gmail.com
EMAIL_SERVER_PASSWORD=mot_de_passe_application
EMAIL_FROM=noreply@reservation-chartrettes.fr
